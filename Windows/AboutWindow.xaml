<ui:FluentWindow
    x:Class="LenovoController.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="About"
    Width="420"
    SizeToContent="Height"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="About"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,8,16,20">

                <!-- DEVICE -->
                <TextBlock Text="Device"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="4,4,0,12"/>

                <ui:Card Padding="16,12">
                    <Grid>
                        <TextBlock Text="Manufacturer"/>
                        <TextBlock x:Name="txtManufacturer"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>

                <ui:Card Padding="16,12" Margin="0,2,0,0">
                    <Grid>
                        <TextBlock Text="Model"/>
                        <TextBlock x:Name="txtModel"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>

                <ui:Card Padding="16,12" Margin="0,2,0,0">
                    <Grid>
                        <TextBlock Text="Machine type"/>
                        <TextBlock x:Name="txtMachineType"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>

                <ui:Card Padding="16,12" Margin="0,2,0,0">
                    <Grid>
                        <TextBlock Text="Serial number"/>
                        <TextBlock x:Name="txtSerial"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>

                <ui:Card Padding="16,12" Margin="0,2,0,0">
                    <Grid>
                        <TextBlock Text="BIOS version"/>
                        <TextBlock x:Name="txtBios"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>


                <!-- SYSTEM -->
                <TextBlock Text="System"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="4,20,0,12"/>

                <ui:Card Padding="16,12">
                    <Grid>
                        <TextBlock Text="Windows edition"/>
                        <TextBlock x:Name="txtWinEdition"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>

                <ui:Card Padding="16,12" Margin="0,2,0,0">
                    <Grid>
                        <TextBlock Text="Version"/>
                        <TextBlock x:Name="txtWinVersion"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>

                <ui:Card Padding="16,12" Margin="0,2,0,0">
                    <Grid>
                        <TextBlock Text="OS build"/>
                        <TextBlock x:Name="txtWinBuild"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>

                <ui:Card Padding="16,12" Margin="0,2,0,0">
                    <Grid>
                        <TextBlock Text="Architecture"/>
                        <TextBlock x:Name="txtWinArch"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>

                <ui:Card Padding="16,12" Margin="0,2,0,0">
                    <Grid>
                        <TextBlock Text="Installed on"/>
                        <TextBlock x:Name="txtInstallDate"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>


                <!-- BATTERY -->
                <TextBlock Text="Battery"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="4,20,0,12"/>

                <ui:Card Padding="16,12">
                    <Grid>
                        <TextBlock Text="Health"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Border Width="80"
                                    Height="8"
                                    CornerRadius="4"
                                    Background="#444"
                                    Margin="0,0,8,0">

                                <Border x:Name="batteryHealthBar"
                                        Width="0"
                                        Height="8"
                                        CornerRadius="4"
                                        Background="#4CAF50"/>
                            </Border>

                            <TextBlock x:Name="txtBatteryHealth"
                                       Opacity="0.7"/>
                        </StackPanel>
                    </Grid>
                </ui:Card>

                <ui:Card Padding="16,12" Margin="0,2,0,0">
                    <Grid>
                        <TextBlock Text="Design capacity"/>
                        <TextBlock x:Name="txtBatteryDesign"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>

                <ui:Card Padding="16,12" Margin="0,2,0,0">
                    <Grid>
                        <TextBlock Text="Full charge capacity"/>
                        <TextBlock x:Name="txtBatteryFull"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>

                <ui:Card Padding="16,12" Margin="0,2,0,0">
                    <Grid>
                        <TextBlock Text="Cycle count"/>
                        <TextBlock x:Name="txtBatteryCycles"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>


                <!-- WARRANTY -->
                <TextBlock Text="Warranty"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="4,20,0,12"/>

                <ui:Card Padding="16,12">
                    <Grid>
                        <TextBlock Text="Start date"/>
                        <TextBlock x:Name="txtWarrantyStart"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>

                <ui:Card Padding="16,12" Margin="0,2,0,0">
                    <Grid>
                        <TextBlock Text="End date"/>
                        <TextBlock x:Name="txtWarrantyEnd"
                                   HorizontalAlignment="Right"
                                   Opacity="0.7"/>
                    </Grid>
                </ui:Card>

                <ui:Button Margin="0,8,0,0"
                           Click="BtnRefreshWarranty_Click"
                           Content="Refresh warranty"/>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</ui:FluentWindow>
