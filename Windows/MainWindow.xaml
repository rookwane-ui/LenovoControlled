<Window x:Class="LenovoController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title=" Lenovo Controller"
        WindowStartupLocation="CenterScreen"
        Width="480"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        Closing="Window_Closing"
        Background="Transparent"
        RenderOptions.BitmapScalingMode="HighQuality"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI Variable Text, Segoe UI, sans-serif"
        Grid.IsSharedSizeScope="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/WindowResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="#1A1A1A"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Foreground" Value="#F3F3F3"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style BasedOn="{StaticResource CustomButton}" TargetType="{x:Type Button}">
                <Setter Property="Background" Value="#F5F5F5"/>
                <Setter Property="Foreground" Value="#1A1A1A"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Background" Value="#3A3A3A"/>
                        <Setter Property="Foreground" Value="#F3F3F3"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Reusable card style -->
            <Style x:Key="Card" TargetType="{x:Type Border}">
                <Setter Property="Background"      Value="#F9F9F9"/>
                <Setter Property="BorderBrush"     Value="#EBEBEB"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="8"/>
                <Setter Property="Padding"         Value="16,12"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Background"  Value="#2D2D2D"/>
                        <Setter Property="BorderBrush" Value="#3A3A3A"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Group card variants -->
            <Style x:Key="CardTop" TargetType="{x:Type Border}" BasedOn="{StaticResource Card}">
                <Setter Property="CornerRadius"    Value="8,8,0,0"/>
                <Setter Property="BorderThickness" Value="1,1,1,0"/>
            </Style>
            <Style x:Key="CardMid" TargetType="{x:Type Border}" BasedOn="{StaticResource Card}">
                <Setter Property="CornerRadius"    Value="0"/>
                <Setter Property="BorderThickness" Value="1,0,1,0"/>
            </Style>
            <Style x:Key="CardBot" TargetType="{x:Type Border}" BasedOn="{StaticResource Card}">
                <Setter Property="CornerRadius"    Value="0,0,8,8"/>
                <Setter Property="BorderThickness" Value="1,0,1,1"/>
            </Style>

            <!-- Separator inside grouped card -->
            <Style x:Key="CardSeparator" TargetType="{x:Type Border}">
                <Setter Property="Height"     Value="1"/>
                <Setter Property="Margin"     Value="16,0"/>
                <Setter Property="Background" Value="#EBEBEB"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Background" Value="#3A3A3A"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Section header label -->
            <Style x:Key="SectionLabel" TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize"   Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin"     Value="4,0,0,6"/>
            </Style>

            <!-- Card title -->
            <Style x:Key="CardTitle" TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize" Value="13"/>
            </Style>

            <!-- Card subtitle -->
            <Style x:Key="CardSubtitle" TargetType="{x:Type TextBlock}"
                   BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Margin"   Value="0,2,0,0"/>
                <Setter Property="Foreground" Value="#888888"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Foreground" Value="#9D9D9D"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Segmented pill track -->
            <Style x:Key="SegTrack" TargetType="{x:Type Border}">
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding"      Value="3"/>
                <Setter Property="Background"   Value="#E5E5E5"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Background" Value="#252525"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Segment RadioButton -->
            <Style x:Key="Segment" TargetType="{x:Type RadioButton}">
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template"         Value="{StaticResource SegmentLight}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Template" Value="{StaticResource SegmentDark}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Toggle switch CheckBox -->
            <Style x:Key="Toggle" TargetType="{x:Type CheckBox}">
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template"         Value="{StaticResource ToggleSwitchLight}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Template" Value="{StaticResource ToggleSwitchDark}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <StackPanel Margin="16,16,16,0">

        <!-- ══════════════════════════════════════════
             BATTERY CHARGE
        ══════════════════════════════════════════ -->
        <TextBlock x:Name="batteryGroup" Text="Battery charge" Style="{StaticResource SectionLabel}"/>

        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="32" Height="32" CornerRadius="6" Background="#FFF3E0"
                        HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Image Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Source="../Resources/Icons/Battery_white.png"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="batteryTitle" Style="{StaticResource CardTitle}" Text="Battery charge"/>
                    <TextBlock x:Name="batterySubtitle" Style="{StaticResource CardSubtitle}"/>
                </StackPanel>

                <!-- Segmented control -->
                <Border Grid.Column="2" Style="{StaticResource SegTrack}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="radioConservation" GroupName="BatteryCharge"
                                     Content="Conservation" Style="{StaticResource Segment}"
                                     Checked="radioBattery_Checked"/>
                        <RadioButton x:Name="radioNormalCharge" GroupName="BatteryCharge"
                                     Content="Normal" Style="{StaticResource Segment}"
                                     Checked="radioBattery_Checked"/>
                        <RadioButton x:Name="radioRapidCharge" GroupName="BatteryCharge"
                                     Content="Rapid" Style="{StaticResource Segment}"
                                     Checked="radioBattery_Checked"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             POWER MODE
        ══════════════════════════════════════════ -->
        <TextBlock x:Name="powerModeGroup" Text="Power mode" Style="{StaticResource SectionLabel}"
                   Margin="4,16,0,6"/>

        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="32" Height="32" CornerRadius="6" Background="#E8F5E9"
                        HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Image Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Source="../Resources/Icons/Power_white.png"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="powerTitle" Style="{StaticResource CardTitle}" Text="Power mode"/>
                    <TextBlock x:Name="powerSubtitle" Style="{StaticResource CardSubtitle}"/>
                </StackPanel>

                <Border Grid.Column="2" Style="{StaticResource SegTrack}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="radioQuiet" GroupName="PowerMode"
                                     Content="Quiet" Style="{StaticResource Segment}"
                                     Checked="radioPowerMode_Checked"/>
                        <RadioButton x:Name="radioBalance" GroupName="PowerMode"
                                     Content="Balance" Style="{StaticResource Segment}"
                                     Checked="radioPowerMode_Checked"/>
                        <RadioButton x:Name="radioPerformance" GroupName="PowerMode"
                                     Content="Performance" Style="{StaticResource Segment}"
                                     Checked="radioPowerMode_Checked"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             ALWAYS ON USB
        ══════════════════════════════════════════ -->
        <TextBlock x:Name="alwaysGroup" Text="Always on USB" Style="{StaticResource SectionLabel}"
                   Margin="4,16,0,6"/>

        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="32" Height="32" CornerRadius="6" Background="#E3F2FD"
                        HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Image Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Source="../Resources/Icons/Usb_white.png"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="usbTitle" Style="{StaticResource CardTitle}" Text="Always on USB"/>
                    <TextBlock x:Name="usbSubtitle" Style="{StaticResource CardSubtitle}"/>
                </StackPanel>

                <Border Grid.Column="2" Style="{StaticResource SegTrack}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="radioAlwaysOnUsbOff" GroupName="Usb"
                                     Content="Off" Style="{StaticResource Segment}"
                                     Checked="radioAlwaysOnUsb_Checked"/>
                        <RadioButton x:Name="radioAlwaysOnUsbOnWhenSleeping" GroupName="Usb"
                                     Content="Sleeping" Style="{StaticResource Segment}"
                                     Checked="radioAlwaysOnUsb_Checked"/>
                        <RadioButton x:Name="radioAlwaysOnUsbOnAlways" GroupName="Usb"
                                     Content="Always" Style="{StaticResource Segment}"
                                     Checked="radioAlwaysOnUsb_Checked"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             ADDITIONAL OPTIONS  (grouped card)
        ══════════════════════════════════════════ -->
        <TextBlock x:Name="miscGroup" Text="Additional options" Style="{StaticResource SectionLabel}"
                   Margin="4,16,0,6"/>

        <!-- Fn Lock row (TOP) -->
        <Border Style="{StaticResource CardTop}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="32" Height="32" CornerRadius="6" Background="#EDE7F6"
                        HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Image Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Source="../Resources/Icons/Fn_white.png"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="fnLockTitle" Style="{StaticResource CardTitle}" Text="Fn Lock"/>
                    <TextBlock x:Name="fnLockSubtitle" Style="{StaticResource CardSubtitle}"
                               Text="Emulates holding the Fn key permanently"/>
                </StackPanel>
                <CheckBox x:Name="chkFnLock" Grid.Column="2" Style="{StaticResource Toggle}"
                          VerticalAlignment="Center"
                          Checked="chkFnLock_Checked" Unchecked="chkFnLock_Checked"/>
            </Grid>
        </Border>

        <Border Style="{StaticResource CardSeparator}"/>

        <!-- Touchpad row (BOTTOM) -->
        <Border Style="{StaticResource CardBot}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="32" Height="32" CornerRadius="6" Background="#E0F7FA"
                        HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Image Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Source="../Resources/Icons/Touch_white.png"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="touchpadTitle" Style="{StaticResource CardTitle}" Text="Touchpad"/>
                    <TextBlock x:Name="touchpadSubtitle" Style="{StaticResource CardSubtitle}"
                               Text="Enable or disable the touchpad"/>
                </StackPanel>
                <CheckBox x:Name="chkTouchpadLock" Grid.Column="2" Style="{StaticResource Toggle}"
                          VerticalAlignment="Center"
                          Checked="chkTouchpadLock_Checked" Unchecked="chkTouchpadLock_Checked"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             FOOTER
        ══════════════════════════════════════════ -->
        <Grid Margin="0,16,0,16" Height="34">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="88"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnRefresh" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Content="Refresh" Click="btnRefresh_Click"/>
            <Button x:Name="btnSettings" Grid.Column="1" HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" Padding="0" Margin="8,0" Click="btnSettings_Click">
                <Image Source="../Resources/Icons/Settings.png" Width="15" Height="15"/>
            </Button>
            <Button x:Name="btnExit" Grid.Column="2" HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" Content="Exit" Click="btnExit_Click"/>
        </Grid>

    </StackPanel>
</Window>
