<Window x:Class="LenovoController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title=" Lenovo Controller"
        WindowStartupLocation="CenterScreen"
        Width="300" Height="543"
        ResizeMode="CanMinimize"
        Closing="Window_Closing"
        RenderOptions.BitmapScalingMode="HighQuality"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Style>
        <Style TargetType="{x:Type Window}">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DarkMode}" Value="True">
                    <Setter Property="Background" Value="#1E1E1E"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/WindowResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Section header panel -->
            <Style x:Key="StackPanelHeader" TargetType="{x:Type Border}">
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Background" Value="#2D2D2D"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Section header text -->
            <Style x:Key="TextBlockHeader" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="#E74C3C"/>
                <Setter Property="LetterSpacing" Value="1"/>
            </Style>

            <!-- Body text color -->
            <Style x:Key="TextBlockBody" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="#222222"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Foreground" Value="#D4D4D4"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- CheckBox -->
            <Style TargetType="{x:Type CheckBox}">
                <Setter Property="SnapsToDevicePixels" Value="true"/>
                <Setter Property="OverridesDefaultStyle" Value="true"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Foreground" Value="#222222"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
                <Setter Property="Template" Value="{StaticResource CheckBoxWhite}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Foreground" Value="#D4D4D4"/>
                        <Setter Property="Template" Value="{StaticResource CheckBoxDark}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- RadioButton -->
            <Style TargetType="{x:Type RadioButton}">
                <Setter Property="SnapsToDevicePixels" Value="true"/>
                <Setter Property="OverridesDefaultStyle" Value="true"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="#222222"/>
                <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
                <Setter Property="Template" Value="{StaticResource RadioButtonWhite}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Foreground" Value="#D4D4D4"/>
                        <Setter Property="Template" Value="{StaticResource RadioButtonDark}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Button -->
            <Style BasedOn="{StaticResource CustomButton}" TargetType="{x:Type Button}">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="Foreground" Value="#111111"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Background" Value="#3A3A3A"/>
                        <Setter Property="Foreground" Value="#E0E0E0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>  <!-- Battery header -->
            <RowDefinition Height="auto"/>  <!-- Battery options -->
            <RowDefinition Height="auto"/>  <!-- Power header -->
            <RowDefinition Height="auto"/>  <!-- Power options -->
            <RowDefinition Height="auto"/>  <!-- USB header -->
            <RowDefinition Height="auto"/>  <!-- USB options -->
            <RowDefinition Height="auto"/>  <!-- Misc header -->
            <RowDefinition Height="auto"/>  <!-- Misc options -->
            <RowDefinition Height="auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ═══════════════ BATTERY CHARGE ═══════════════ -->
        <Border Grid.Row="0" Margin="12,12,12,0" Style="{StaticResource StackPanelHeader}">
            <TextBlock x:Name="batteryGroup" Margin="10,5,10,5"
                       Style="{StaticResource TextBlockHeader}" Text="BATTERY CHARGE"/>
        </Border>

        <Grid Grid.Row="1" Margin="12,4,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Height="48" Margin="4,4,4,4"
                   HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image.Style>
                    <Style TargetType="{x:Type Image}">
                        <Setter Property="Source" Value="../Resources/Icons/Battery_white.png"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DarkMode}" Value="True">
                                <Setter Property="Source" Value="../Resources/Icons/Battery_black.png"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <RadioButton x:Name="radioConservation" GroupName="BatteryCharge" Margin="0,3,0,3"
                             Content="Conservation" Checked="radioBattery_Checked" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="radioNormalCharge" GroupName="BatteryCharge" Margin="0,3,0,3"
                             Content="Normal" Checked="radioBattery_Checked" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="radioRapidCharge" GroupName="BatteryCharge" Margin="0,3,0,3"
                             Content="Rapid Charge" Checked="radioBattery_Checked" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════ POWER MODE ═══════════════ -->
        <Border Grid.Row="2" Margin="12,6,12,0" Style="{StaticResource StackPanelHeader}">
            <TextBlock x:Name="powerModeGroup" Margin="10,5,10,5"
                       Style="{StaticResource TextBlockHeader}" Text="POWER MODE"/>
        </Border>

        <Grid Grid.Row="3" Margin="12,4,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Height="40" Margin="4,4,4,4"
                   HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image.Style>
                    <Style TargetType="{x:Type Image}">
                        <Setter Property="Source" Value="../Resources/Icons/Power_white.png"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DarkMode}" Value="True">
                                <Setter Property="Source" Value="../Resources/Icons/Power_black.png"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <RadioButton x:Name="radioQuiet" GroupName="PowerMode" Margin="0,3,0,3"
                             Content="Quiet" Checked="radioPowerMode_Checked" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="radioBalance" GroupName="PowerMode" Margin="0,3,0,3"
                             Content="Balance" Checked="radioPowerMode_Checked" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="radioPerformance" GroupName="PowerMode" Margin="0,3,0,3"
                             Content="Performance" Checked="radioPowerMode_Checked" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════ ALWAYS ON USB ═══════════════ -->
        <Border Grid.Row="4" Margin="12,6,12,0" Style="{StaticResource StackPanelHeader}">
            <TextBlock x:Name="alwaysGroup" Margin="10,5,10,5"
                       Style="{StaticResource TextBlockHeader}" Text="ALWAYS ON USB"/>
        </Border>

        <Grid Grid.Row="5" Margin="12,4,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Height="46" Margin="4,4,4,4"
                   HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image.Style>
                    <Style TargetType="{x:Type Image}">
                        <Setter Property="Source" Value="../Resources/Icons/Usb_white.png"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DarkMode}" Value="True">
                                <Setter Property="Source" Value="../Resources/Icons/Usb_black.png"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <RadioButton x:Name="radioAlwaysOnUsbOff" GroupName="Usb" Margin="0,3,0,3"
                             Content="Off" Checked="radioAlwaysOnUsb_Checked"
                             Unchecked="radioAlwaysOnUsb_Checked" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="radioAlwaysOnUsbOnWhenSleeping" GroupName="Usb" Margin="0,3,0,3"
                             Content="On when sleeping" Checked="radioAlwaysOnUsb_Checked"
                             Unchecked="radioAlwaysOnUsb_Checked" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="radioAlwaysOnUsbOnAlways" GroupName="Usb" Margin="0,3,0,3"
                             Content="On always" Checked="radioAlwaysOnUsb_Checked"
                             Unchecked="radioAlwaysOnUsb_Checked" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════ ADDITIONAL OPTIONS ═══════════════ -->
        <Border Grid.Row="6" Margin="12,6,12,0" Style="{StaticResource StackPanelHeader}">
            <TextBlock x:Name="miscGroup" Margin="10,5,10,5"
                       Style="{StaticResource TextBlockHeader}" Text="ADDITIONAL OPTIONS"/>
        </Border>

        <Grid Grid.Row="7" Margin="12,4,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4">
                <Image Height="22" Margin="0,3,0,3">
                    <Image.Style>
                        <Style TargetType="{x:Type Image}">
                            <Setter Property="Source" Value="../Resources/Icons/Display_white.png"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DarkMode}" Value="True">
                                    <Setter Property="Source" Value="../Resources/Icons/Display_black.png"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <Image Height="22" Margin="0,3,0,3">
                    <Image.Style>
                        <Style TargetType="{x:Type Image}">
                            <Setter Property="Source" Value="../Resources/Icons/Fn_white.png"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DarkMode}" Value="True">
                                    <Setter Property="Source" Value="../Resources/Icons/Fn_black.png"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <Image Height="22" Margin="0,3,0,3">
                    <Image.Style>
                        <Style TargetType="{x:Type Image}">
                            <Setter Property="Source" Value="../Resources/Icons/Touch_white.png"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DarkMode}" Value="True">
                                    <Setter Property="Source" Value="../Resources/Icons/Touch_black.png"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <CheckBox x:Name="chkOverDrive" Margin="0,3,0,3" Content="On Over Drive"
                          Checked="chkOverDrive_Checked" Unchecked="chkOverDrive_Checked" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkFnLock" Margin="0,3,0,3" Content="On FnLock"
                          Checked="chkFnLock_Checked" Unchecked="chkFnLock_Checked" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkTouchpadLock" Margin="0,3,0,3" Content="On touchpad"
                          Checked="chkTouchpadLock_Checked" Unchecked="chkTouchpadLock_Checked" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════ FOOTER ═══════════════ -->
        <Border Grid.Row="8" Margin="0,8,0,0">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Background" Value="#DCDCDC"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DarkMode}" Value="True">
                            <Setter Property="Background" Value="#2A2A2A"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid Margin="12,10,12,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnRefresh" Height="30" HorizontalAlignment="Stretch"
                        Content="REFRESH" Click="btnRefresh_Click"/>
                <Button x:Name="btnSettings" Grid.Column="1" Height="30" Width="34" Padding="6"
                        Margin="8,0,8,0" HorizontalAlignment="Center" Click="btnSettings_Click">
                    <Image Source="../Resources/Icons/Settings.png"/>
                </Button>
                <Button x:Name="btnExit" Grid.Column="2" Height="30" Width="80"
                        Content="EXIT" Click="btnExit_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>
