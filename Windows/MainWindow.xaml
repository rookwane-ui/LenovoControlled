<ui:FluentWindow
        x:Class="LenovoController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Lenovo Controller"
        Width="460"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        Closing="Window_Closing"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <Style x:Key="SegmentStyle" TargetType="{x:Type RadioButton}">
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="FocusVisualStyle"      Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="Bg" CornerRadius="6" Padding="10,5"
                                Background="Transparent" SnapsToDevicePixels="True">
                            <TextBlock x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg"    Property="Background"
                                        Value="{DynamicResource ControlFillColorInputActiveBrush}"/>
                                <Setter TargetName="Label" Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Label" Property="Foreground"
                                        Value="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Label" Property="Foreground"
                                        Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Label" Property="Foreground"
                                        Value="{DynamicResource TextFillColorDisabledBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

<Grid>
            <!-- POWER MODE -->
            <ui:Card Grid.Row="1" Margin="0,0,0,12" Padding="12">
                <StackPanel>
                    <TextBlock Text="Power Mode" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Efficiency" Tag="PowerMode" CommandParameter="0"
                                     Checked="RadioGroup_Checked"/>
                        <RadioButton Content="Balanced" Tag="PowerMode" CommandParameter="1"
                                     Checked="RadioGroup_Checked"/>
                        <RadioButton Content="Performance" Tag="PowerMode" CommandParameter="2"
                                     Checked="RadioGroup_Checked"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- USB -->
            <ui:Card Grid.Row="2" Margin="0,0,0,12" Padding="12">
                <StackPanel>
                    <TextBlock Text="Always On USB" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Off" Tag="Usb" CommandParameter="0"
                                     Checked="RadioGroup_Checked"/>
                        <RadioButton Content="Sleeping" Tag="Usb" CommandParameter="1"
                                     Checked="RadioGroup_Checked"/>
                        <RadioButton Content="Always" Tag="Usb" CommandParameter="2"
                                     Checked="RadioGroup_Checked"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- TOGGLES -->
            <ui:Card Grid.Row="3" Margin="0,0,0,12" Padding="12">
                <StackPanel>
                    <ui:ToggleSwitch x:Name="chkFnLock"
                                     Content="Fn Lock"
                                     Checked="chkFnLock_Checked"
                                     Unchecked="chkFnLock_Checked"/>
                    <ui:ToggleSwitch x:Name="chkTouchpadLock"
                                     Content="Touchpad"
                                     Checked="chkTouchpadLock_Checked"
                                     Unchecked="chkTouchpadLock_Checked"/>
                </StackPanel>
            </ui:Card>

            <!-- FOOTER -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Refresh" Click="btnRefresh_Click" Margin="0,0,8,0"/>
                <ui:Button Content="Settings" Click="btnSettings_Click" Margin="0,0,8,0"/>
                <ui:Button Content="About" Click="btnAbout_Click" Margin="0,0,8,0"/>
                <ui:Button Content="Exit" Click="btnExit_Click" Appearance="Secondary"/>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</Grid>

</ui:FluentWindow>
