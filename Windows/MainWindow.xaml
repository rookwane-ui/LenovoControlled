<Window x:Class="LenovoController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title=" Lenovo Controller"
        WindowStartupLocation="CenterScreen"
        Width="300"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        Closing="Window_Closing"
        RenderOptions.BitmapScalingMode="HighQuality"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Style>
        <Style TargetType="{x:Type Window}">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DarkMode}" Value="True">
                    <Setter Property="Background" Value="#1E1E1E"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/WindowResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="StackPanelHeader" TargetType="{x:Type Border}">
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Background" Value="#2D2D2D"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="TextBlockHeader" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="#E74C3C"/>
            </Style>

            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="#222222"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Foreground" Value="#D4D4D4"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Modern toggle switch for RadioButton - Light -->
            <ControlTemplate x:Key="ToggleRadioWhite" TargetType="{x:Type RadioButton}">
                <Grid Background="Transparent" SnapsToDevicePixels="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="Track" Height="18" Width="34" CornerRadius="9"
                            Background="#CCCCCC" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Border x:Name="Thumb" Height="12" Width="12" CornerRadius="6"
                                Background="#FFFFFF" HorizontalAlignment="Left"
                                VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </Border>
                    <ContentPresenter Grid.Column="1" VerticalAlignment="Center"
                                      HorizontalAlignment="Left" RecognizesAccessKey="True"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="Track" Property="Background" Value="#E74C3C"/>
                        <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                        <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="Track" Property="Opacity" Value="0.4"/>
                        <Setter Property="Foreground" Value="#AAAAAA"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- Modern toggle switch for RadioButton - Dark -->
            <ControlTemplate x:Key="ToggleRadioDark" TargetType="{x:Type RadioButton}">
                <Grid Background="Transparent" SnapsToDevicePixels="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="Track" Height="18" Width="34" CornerRadius="9"
                            Background="#555555" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Border x:Name="Thumb" Height="12" Width="12" CornerRadius="6"
                                Background="#AAAAAA" HorizontalAlignment="Left"
                                VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </Border>
                    <ContentPresenter Grid.Column="1" VerticalAlignment="Center"
                                      HorizontalAlignment="Left" RecognizesAccessKey="True"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="Track" Property="Background" Value="#E74C3C"/>
                        <Setter TargetName="Thumb" Property="Background" Value="#FFFFFF"/>
                        <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                        <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="Track" Property="Opacity" Value="0.3"/>
                        <Setter Property="Foreground" Value="#666666"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- Modern toggle switch for CheckBox - Light -->
            <ControlTemplate x:Key="ToggleCheckWhite" TargetType="{x:Type CheckBox}">
                <Grid Background="Transparent" SnapsToDevicePixels="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="Track" Height="18" Width="34" CornerRadius="9"
                            Background="#CCCCCC" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Border x:Name="Thumb" Height="12" Width="12" CornerRadius="6"
                                Background="#FFFFFF" HorizontalAlignment="Left"
                                VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </Border>
                    <ContentPresenter Grid.Column="1" VerticalAlignment="Center"
                                      HorizontalAlignment="Left" RecognizesAccessKey="True"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="Track" Property="Background" Value="#E74C3C"/>
                        <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                        <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="Track" Property="Opacity" Value="0.4"/>
                        <Setter Property="Foreground" Value="#AAAAAA"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- Modern toggle switch for CheckBox - Dark -->
            <ControlTemplate x:Key="ToggleCheckDark" TargetType="{x:Type CheckBox}">
                <Grid Background="Transparent" SnapsToDevicePixels="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="Track" Height="18" Width="34" CornerRadius="9"
                            Background="#555555" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Border x:Name="Thumb" Height="12" Width="12" CornerRadius="6"
                                Background="#AAAAAA" HorizontalAlignment="Left"
                                VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </Border>
                    <ContentPresenter Grid.Column="1" VerticalAlignment="Center"
                                      HorizontalAlignment="Left" RecognizesAccessKey="True"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="Track" Property="Background" Value="#E74C3C"/>
                        <Setter TargetName="Thumb" Property="Background" Value="#FFFFFF"/>
                        <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                        <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="Track" Property="Opacity" Value="0.3"/>
                        <Setter Property="Foreground" Value="#666666"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <Style TargetType="{x:Type CheckBox}">
                <Setter Property="SnapsToDevicePixels" Value="true"/>
                <Setter Property="OverridesDefaultStyle" Value="true"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Foreground" Value="#222222"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
                <Setter Property="Template" Value="{StaticResource ToggleCheckWhite}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Foreground" Value="#D4D4D4"/>
                        <Setter Property="Template" Value="{StaticResource ToggleCheckDark}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type RadioButton}">
                <Setter Property="SnapsToDevicePixels" Value="true"/>
                <Setter Property="OverridesDefaultStyle" Value="true"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="#222222"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
                <Setter Property="Template" Value="{StaticResource ToggleRadioWhite}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Foreground" Value="#D4D4D4"/>
                        <Setter Property="Template" Value="{StaticResource ToggleRadioDark}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style BasedOn="{StaticResource CustomButton}" TargetType="{x:Type Button}">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="Foreground" Value="#111111"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DarkMode}" Value="True">
                        <Setter Property="Background" Value="#3A3A3A"/>
                        <Setter Property="Foreground" Value="#E0E0E0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <StackPanel>

        <!-- ═══════════════ BATTERY CHARGE ═══════════════ -->
        <Border Margin="12,12,12,0" Style="{StaticResource StackPanelHeader}">
            <TextBlock x:Name="batteryGroup" Margin="10,5,10,5"
                       Style="{StaticResource TextBlockHeader}" Text="BATTERY CHARGE"/>
        </Border>
        <Grid Margin="12,6,12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Height="48" Margin="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image.Style>
                    <Style TargetType="{x:Type Image}">
                        <Setter Property="Source" Value="../Resources/Icons/Battery_white.png"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DarkMode}" Value="True">
                                <Setter Property="Source" Value="../Resources/Icons/Battery_black.png"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,4">
                <RadioButton x:Name="radioConservation" GroupName="BatteryCharge" Margin="0,4,0,4"
                             Content="Conservation" Checked="radioBattery_Checked" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="radioNormalCharge" GroupName="BatteryCharge" Margin="0,4,0,4"
                             Content="Normal" Checked="radioBattery_Checked" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="radioRapidCharge" GroupName="BatteryCharge" Margin="0,4,0,4"
                             Content="Rapid Charge" Checked="radioBattery_Checked" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════ POWER MODE ═══════════════ -->
        <Border Margin="12,6,12,0" Style="{StaticResource StackPanelHeader}">
            <TextBlock x:Name="powerModeGroup" Margin="10,5,10,5"
                       Style="{StaticResource TextBlockHeader}" Text="POWER MODE"/>
        </Border>
        <Grid Margin="12,6,12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Height="40" Margin="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image.Style>
                    <Style TargetType="{x:Type Image}">
                        <Setter Property="Source" Value="../Resources/Icons/Power_white.png"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DarkMode}" Value="True">
                                <Setter Property="Source" Value="../Resources/Icons/Power_black.png"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,4">
                <RadioButton x:Name="radioQuiet" GroupName="PowerMode" Margin="0,4,0,4"
                             Content="Quiet" Checked="radioPowerMode_Checked" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="radioBalance" GroupName="PowerMode" Margin="0,4,0,4"
                             Content="Balance" Checked="radioPowerMode_Checked" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="radioPerformance" GroupName="PowerMode" Margin="0,4,0,4"
                             Content="Performance" Checked="radioPowerMode_Checked" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════ ALWAYS ON USB ═══════════════ -->
        <Border Margin="12,6,12,0" Style="{StaticResource StackPanelHeader}">
            <TextBlock x:Name="alwaysGroup" Margin="10,5,10,5"
                       Style="{StaticResource TextBlockHeader}" Text="ALWAYS ON USB"/>
        </Border>
        <Grid Margin="12,6,12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Height="46" Margin="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image.Style>
                    <Style TargetType="{x:Type Image}">
                        <Setter Property="Source" Value="../Resources/Icons/Usb_white.png"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DarkMode}" Value="True">
                                <Setter Property="Source" Value="../Resources/Icons/Usb_black.png"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,4">
                <RadioButton x:Name="radioAlwaysOnUsbOff" GroupName="Usb" Margin="0,4,0,4"
                             Content="Off" Checked="radioAlwaysOnUsb_Checked"
                             Unchecked="radioAlwaysOnUsb_Checked" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="radioAlwaysOnUsbOnWhenSleeping" GroupName="Usb" Margin="0,4,0,4"
                             Content="On when sleeping" Checked="radioAlwaysOnUsb_Checked"
                             Unchecked="radioAlwaysOnUsb_Checked" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="radioAlwaysOnUsbOnAlways" GroupName="Usb" Margin="0,4,0,4"
                             Content="On always" Checked="radioAlwaysOnUsb_Checked"
                             Unchecked="radioAlwaysOnUsb_Checked" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════ ADDITIONAL OPTIONS ═══════════════ -->
        <Border Margin="12,6,12,0" Style="{StaticResource StackPanelHeader}">
            <TextBlock x:Name="miscGroup" Margin="10,5,10,5"
                       Style="{StaticResource TextBlockHeader}" Text="ADDITIONAL OPTIONS"/>
        </Border>
        <Grid Margin="12,6,12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4">
                <Image Height="22" Margin="0,5,0,5">
                    <Image.Style>
                        <Style TargetType="{x:Type Image}">
                            <Setter Property="Source" Value="../Resources/Icons/Display_white.png"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DarkMode}" Value="True">
                                    <Setter Property="Source" Value="../Resources/Icons/Display_black.png"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <Image Height="22" Margin="0,5,0,5">
                    <Image.Style>
                        <Style TargetType="{x:Type Image}">
                            <Setter Property="Source" Value="../Resources/Icons/Fn_white.png"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DarkMode}" Value="True">
                                    <Setter Property="Source" Value="../Resources/Icons/Fn_black.png"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <Image Height="22" Margin="0,5,0,5">
                    <Image.Style>
                        <Style TargetType="{x:Type Image}">
                            <Setter Property="Source" Value="../Resources/Icons/Touch_white.png"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DarkMode}" Value="True">
                                    <Setter Property="Source" Value="../Resources/Icons/Touch_black.png"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,4,0,4">
                <CheckBox x:Name="chkOverDrive" Margin="0,5,0,5" Content="On Over Drive"
                          Checked="chkOverDrive_Checked" Unchecked="chkOverDrive_Checked"
                          VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkFnLock" Margin="0,5,0,5" Content="On FnLock"
                          Checked="chkFnLock_Checked" Unchecked="chkFnLock_Checked"
                          VerticalContentAlignment="Center"/>
                <CheckBox x:Name="chkTouchpadLock" Margin="0,5,0,5" Content="On touchpad"
                          Checked="chkTouchpadLock_Checked" Unchecked="chkTouchpadLock_Checked"
                          VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════ FOOTER ═══════════════ -->
        <Border Margin="0,8,0,0">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Background" Value="#DCDCDC"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DarkMode}" Value="True">
                            <Setter Property="Background" Value="#2A2A2A"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid Margin="12,10,12,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnRefresh" Height="30" HorizontalAlignment="Stretch"
                        Content="REFRESH" Click="btnRefresh_Click"/>
                <Button x:Name="btnSettings" Grid.Column="1" Height="30" Width="34" Padding="6"
                        Margin="8,0,8,0" HorizontalAlignment="Center" Click="btnSettings_Click">
                    <Image Source="../Resources/Icons/Settings.png"/>
                </Button>
                <Button x:Name="btnExit" Grid.Column="2" Height="30" Width="80"
                        Content="EXIT" Click="btnExit_Click"/>
            </Grid>
        </Border>

    </StackPanel>
</Window>
