<ui:FluentWindow
        x:Class="LenovoController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Lenovo Controller"
        Width="460"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        Closing="Window_Closing"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <Style x:Key="SegmentStyle" TargetType="{x:Type RadioButton}">
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="FocusVisualStyle"      Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="Bg" CornerRadius="6" Padding="10,5"
                                Background="Transparent" SnapsToDevicePixels="True">
                            <TextBlock x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg"    Property="Background"
                                        Value="{DynamicResource ControlFillColorInputActiveBrush}"/>
                                <Setter TargetName="Label" Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Label" Property="Foreground"
                                        Value="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Label" Property="Foreground"
                                        Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Label" Property="Foreground"
                                        Value="{DynamicResource TextFillColorDisabledBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- WPF-UI title bar with Mica -->
        <ui:TitleBar Grid.Row="0" Title="Lenovo Controller"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,8,16,16">

                <!-- ══ BATTERY CHARGE ══ -->
                <TextBlock x:Name="batteryGroup"
                           Text="Battery charge"
                           FontSize="13" FontWeight="SemiBold"
                           Margin="4,8,0,6"/>

                <ui:Card Margin="0,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="#FFF3E0" HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="BatteryCharge24" FontSize="20"
                                                      Foreground="#E65100"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock x:Name="batteryTitle" Text="Battery charge" FontSize="13"/>
                            <TextBlock x:Name="batterySubtitle" FontSize="11"
                                       Margin="0,2,0,0" Opacity="0.6"/>
                        </StackPanel>
                        <!-- Segmented control -->
                        <Border Grid.Column="2" VerticalAlignment="Center"
                                CornerRadius="8" Padding="3"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="radioConservation" GroupName="BatteryCharge"
                                             Content="Conservation"
                                             Style="{StaticResource SegmentStyle}"
                                             Checked="radioBattery_Checked"/>
                                <RadioButton x:Name="radioNormalCharge" GroupName="BatteryCharge"
                                             Content="Normal"
                                             Style="{StaticResource SegmentStyle}"
                                             Checked="radioBattery_Checked"/>
                                <RadioButton x:Name="radioRapidCharge" GroupName="BatteryCharge"
                                             Content="Rapid"
                                             Style="{StaticResource SegmentStyle}"
                                             Checked="radioBattery_Checked"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ui:Card>

                <!-- ══ POWER MODE ══ -->
                <TextBlock x:Name="powerModeGroup"
                           Text="Power mode"
                           FontSize="13" FontWeight="SemiBold"
                           Margin="4,16,0,6"/>

                <ui:Card>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="#E8F5E9" HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Grid.RowSpan="2">
                            <ui:SymbolIcon Symbol="LeafOne24" FontSize="18"
                                           Foreground="#2E7D32"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                        </Border>

                        <!-- Title row -->
                        <TextBlock x:Name="powerTitle" Grid.Column="1"
                                   Text="Power mode" FontSize="13"
                                   VerticalAlignment="Center"/>

                        <!-- Segment control spans both rows on the right -->
                        <Border Grid.Column="2" Grid.RowSpan="2"
                                VerticalAlignment="Center"
                                CornerRadius="8" Padding="3"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="radioQuiet" GroupName="PowerMode"
                                             Content="Efficiency"
                                             Style="{StaticResource SegmentStyle}"
                                             Checked="radioPowerMode_Checked"/>
                                <RadioButton x:Name="radioBalance" GroupName="PowerMode"
                                             Content="Balanced"
                                             Style="{StaticResource SegmentStyle}"
                                             Checked="radioPowerMode_Checked"/>
                                <RadioButton x:Name="radioPerformance" GroupName="PowerMode"
                                             Content="Performance"
                                             Style="{StaticResource SegmentStyle}"
                                             Checked="radioPowerMode_Checked"/>
                            </StackPanel>
                        </Border>

                        <!-- Subtitle below title -->
                        <TextBlock x:Name="powerSubtitle" Grid.Row="1" Grid.Column="1"
                                   Text="Controls performance and battery life"
                                   FontSize="11" Margin="0,2,8,0" Opacity="0.6"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </ui:Card>

                <!-- ══ ALWAYS ON USB ══ -->
                <TextBlock x:Name="alwaysGroup"
                           Text="Always on USB"
                           FontSize="13" FontWeight="SemiBold"
                           Margin="4,16,0,6"/>

                <ui:Card>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="#E3F2FD" HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="PlugConnected24" FontSize="20"
                                                      Foreground="#1565C0"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock x:Name="usbTitle" Text="Always on USB" FontSize="13"/>
                            <TextBlock x:Name="usbSubtitle" FontSize="11"
                                       Margin="0,2,0,0" Opacity="0.6"/>
                        </StackPanel>
                        <Border Grid.Column="2" VerticalAlignment="Center"
                                CornerRadius="8" Padding="3"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="radioAlwaysOnUsbOff" GroupName="Usb"
                                             Content="Off"
                                             Style="{StaticResource SegmentStyle}"
                                             Checked="radioAlwaysOnUsb_Checked"/>
                                <RadioButton x:Name="radioAlwaysOnUsbOnWhenSleeping" GroupName="Usb"
                                             Content="Sleeping"
                                             Style="{StaticResource SegmentStyle}"
                                             Checked="radioAlwaysOnUsb_Checked"/>
                                <RadioButton x:Name="radioAlwaysOnUsbOnAlways" GroupName="Usb"
                                             Content="Always"
                                             Style="{StaticResource SegmentStyle}"
                                             Checked="radioAlwaysOnUsb_Checked"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ui:Card>

                <!-- ══ ADDITIONAL OPTIONS ══ -->
                <TextBlock x:Name="miscGroup"
                           Text="Additional options"
                           FontSize="13" FontWeight="SemiBold"
                           Margin="4,16,0,6"/>

                <!-- Fn Lock -->
                <ui:CardControl Margin="0,0,0,1" MinHeight="64" Padding="16,10">
                    <ui:CardControl.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="#EDE7F6" HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="Keyboard24" FontSize="18"
                                               Foreground="#4527A0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="fnLockTitle" Text="Fn Lock" FontSize="13"/>
                                <TextBlock x:Name="fnLockSubtitle"
                                           Text="Emulates holding the Fn key permanently"
                                           FontSize="11" Margin="0,3,0,0" Opacity="0.6"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="chkFnLock"
                                     Checked="chkFnLock_Checked"
                                     Unchecked="chkFnLock_Checked"/>
                </ui:CardControl>

                <!-- Touchpad -->
                <ui:CardControl MinHeight="64" Padding="16,10">
                    <ui:CardControl.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="#E0F7FA" HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="CursorHover24" FontSize="18"
                                               Foreground="#006064"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="touchpadTitle" Text="Touchpad" FontSize="13"/>
                                <TextBlock x:Name="touchpadSubtitle"
                                           Text="Enable or disable the touchpad"
                                           FontSize="11" Margin="0,3,0,0" Opacity="0.6"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="chkTouchpadLock"
                                     Checked="chkTouchpadLock_Checked"
                                     Unchecked="chkTouchpadLock_Checked"/>
                </ui:CardControl>

                <!-- ══ FOOTER ══ -->
                <Grid Margin="0,16,0,0" Height="34">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="88"/>
                    </Grid.ColumnDefinitions>
                    <ui:Button x:Name="btnAbout" HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch" Content="About"
                               Click="btnAbout_Click"/>
                    <ui:Button x:Name="btnRefresh" Grid.Column="1"
                               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                               Margin="8,0,0,0" Padding="0" ToolTip="Refresh"
                               Click="btnRefresh_Click">
                        <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ui:Button>
                    <ui:Button x:Name="btnSettings" Grid.Column="2"
                               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                               Margin="8,0,0,0" Padding="0" ToolTip="Settings"
                               Click="btnSettings_Click">
                        <ui:SymbolIcon Symbol="Settings24" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ui:Button>
                    <ui:Button x:Name="btnExit" Grid.Column="3"
                               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                               Margin="8,0,0,0"
                               Content="Exit" Click="btnExit_Click"
                               Appearance="Secondary"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</ui:FluentWindow>
