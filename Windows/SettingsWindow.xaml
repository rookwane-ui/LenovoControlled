<ui:FluentWindow
        x:Class="LenovoController.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Settings"
        Width="320"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Settings"/>

        <StackPanel Grid.Row="1" Margin="20,12,20,20">

            <!-- Language -->
            <TextBlock Text="Language" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
            <ComboBox x:Name="langList" Height="32" MaxWidth="200"
                      HorizontalAlignment="Left" Margin="0,0,0,12"/>

            <!-- Options group -->
            <ui:CardControl Margin="0,0,0,4">
                <ui:CardControl.Header>
                    <TextBlock Text="Show on startup" FontSize="13" VerticalAlignment="Center"/>
                </ui:CardControl.Header>
                <ui:ToggleSwitch x:Name="showOnStartup"/>
            </ui:CardControl>

            <ui:CardControl Margin="0,0,0,4">
                <ui:CardControl.Header>
                    <TextBlock Text="Dark theme" FontSize="13" VerticalAlignment="Center"/>
                </ui:CardControl.Header>
                <ui:ToggleSwitch x:Name="darkTheme"/>
            </ui:CardControl>

            <ui:CardControl Margin="0,0,0,16">
                <ui:CardControl.Header>
                    <TextBlock Text="Start with Windows" FontSize="13" VerticalAlignment="Center"/>
                </ui:CardControl.Header>
                <ui:ToggleSwitch x:Name="autoRun"/>
            </ui:CardControl>

            <!-- About -->
            <ui:Card Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ui:FontIcon Glyph="&#xE7F4;" FontSize="36"
                               Foreground="#C0392B"
                               Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Lenovo Controller" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="v2.0.2.0" FontSize="11" Opacity="0.6"/>
                        <TextBlock Text="ViRb3 · 5ORBEX · Doc_DDD" FontSize="11" Opacity="0.6"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Footer buttons -->
            <Grid Height="36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <ui:Button x:Name="btnApply" HorizontalAlignment="Stretch"
                           Content="Apply" Appearance="Primary"
                           Click="btnApply_Click"/>
                <ui:Button x:Name="btnCancel" Grid.Column="2"
                           HorizontalAlignment="Stretch"
                           Content="Cancel" Appearance="Secondary"
                           Click="btnCancel_Click"/>
            </Grid>

        </StackPanel>
    </Grid>
</ui:FluentWindow>
