<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════
         TOOLTIP
    ══════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type ToolTip}">
        <Style.Resources>
            <Style TargetType="{x:Type ContentPresenter}">
                <Style.Resources>
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="TextWrapping" Value="Wrap"/>
                    </Style>
                </Style.Resources>
            </Style>
        </Style.Resources>
        <Setter Property="MaxWidth"        Value="260"/>
        <Setter Property="Background"      Value="#F3F3F3"/>
        <Setter Property="Foreground"      Value="#1A1A1A"/>
        <Setter Property="BorderBrush"     Value="#E0E0E0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="10,6"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         SETTINGS CARD ROW  (the white/dark rounded card)
    ══════════════════════════════════════════════════════════ -->
    <Style x:Key="SettingsCard" TargetType="{x:Type Border}">
        <Setter Property="Background"      Value="#F9F9F9"/>
        <Setter Property="BorderBrush"     Value="#EBEBEB"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="Padding"         Value="16,12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="SettingsCardDark" TargetType="{x:Type Border}">
        <Setter Property="Background"      Value="#2D2D2D"/>
        <Setter Property="BorderBrush"     Value="#3A3A3A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="Padding"         Value="16,12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- Card group: top / middle / bottom get different corner radii -->
    <Style x:Key="SettingsCardTop" TargetType="{x:Type Border}" BasedOn="{StaticResource SettingsCard}">
        <Setter Property="CornerRadius" Value="8,8,0,0"/>
        <Setter Property="BorderThickness" Value="1,1,1,0"/>
    </Style>
    <Style x:Key="SettingsCardMid" TargetType="{x:Type Border}" BasedOn="{StaticResource SettingsCard}">
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="BorderThickness" Value="1,0,1,0"/>
    </Style>
    <Style x:Key="SettingsCardBot" TargetType="{x:Type Border}" BasedOn="{StaticResource SettingsCard}">
        <Setter Property="CornerRadius" Value="0,0,8,8"/>
        <Setter Property="BorderThickness" Value="1,0,1,1"/>
    </Style>
    <Style x:Key="SettingsCardTopDark" TargetType="{x:Type Border}" BasedOn="{StaticResource SettingsCardDark}">
        <Setter Property="CornerRadius" Value="8,8,0,0"/>
        <Setter Property="BorderThickness" Value="1,1,1,0"/>
    </Style>
    <Style x:Key="SettingsCardMidDark" TargetType="{x:Type Border}" BasedOn="{StaticResource SettingsCardDark}">
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="BorderThickness" Value="1,0,1,0"/>
    </Style>
    <Style x:Key="SettingsCardBotDark" TargetType="{x:Type Border}" BasedOn="{StaticResource SettingsCardDark}">
        <Setter Property="CornerRadius" Value="0,0,8,8"/>
        <Setter Property="BorderThickness" Value="1,0,1,1"/>
    </Style>

    <!-- Icon badge (colored rounded square, like Settings) -->
    <Style x:Key="IconBadge" TargetType="{x:Type Border}">
        <Setter Property="Width"           Value="32"/>
        <Setter Property="Height"          Value="32"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
    </Style>

    <!-- Section header text (e.g. "Battery charge") -->
    <Style x:Key="SectionHeader" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize"     Value="13"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Foreground"   Value="#1A1A1A"/>
        <Setter Property="Margin"       Value="0,0,0,6"/>
    </Style>
    <Style x:Key="SectionHeaderDark" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize"     Value="13"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Foreground"   Value="#F3F3F3"/>
        <Setter Property="Margin"       Value="0,0,0,6"/>
    </Style>

    <!-- Card title (primary label) -->
    <Style x:Key="CardTitle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="#1A1A1A"/>
    </Style>
    <Style x:Key="CardTitleDark" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="#F3F3F3"/>
    </Style>

    <!-- Card subtitle (secondary label, grey) -->
    <Style x:Key="CardSubtitle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Foreground" Value="#888888"/>
        <Setter Property="Margin"     Value="0,1,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style x:Key="CardSubtitleDark" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Foreground" Value="#9D9D9D"/>
        <Setter Property="Margin"     Value="0,1,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         WIN11 TOGGLE SWITCH  — Light
    ══════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="ToggleSwitchLight" TargetType="{x:Type CheckBox}">
        <Grid Background="Transparent" SnapsToDevicePixels="True" VerticalAlignment="Center">
            <Border x:Name="Track" Height="20" Width="40" CornerRadius="10"
                    Background="#CCCCCC" VerticalAlignment="Center">
                <Border x:Name="Thumb" Height="14" Width="14" CornerRadius="7"
                        Background="#FFFFFF" VerticalAlignment="Center"
                        HorizontalAlignment="Left" Margin="2,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="3"
                                          Color="#000000" Opacity="0.18" Direction="270"/>
                    </Border.Effect>
                </Border>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Track"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#E74C3C" Duration="0:0:0.15"/>
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="Margin"
                                To="22,0,0,0" Duration="0:0:0.15">
                                <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction>
                            </ThicknessAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Track"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#CCCCCC" Duration="0:0:0.15"/>
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="Margin"
                                To="2,0,0,0" Duration="0:0:0.15">
                                <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction>
                            </ThicknessAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Track" Property="Opacity" Value="0.8"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Track" Property="Opacity" Value="0.38"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- WIN11 TOGGLE SWITCH  — Dark -->
    <ControlTemplate x:Key="ToggleSwitchDark" TargetType="{x:Type CheckBox}">
        <Grid Background="Transparent" SnapsToDevicePixels="True" VerticalAlignment="Center">
            <Border x:Name="Track" Height="20" Width="40" CornerRadius="10"
                    Background="#555555" VerticalAlignment="Center">
                <Border x:Name="Thumb" Height="14" Width="14" CornerRadius="7"
                        Background="#AAAAAA" VerticalAlignment="Center"
                        HorizontalAlignment="Left" Margin="2,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="3"
                                          Color="#000000" Opacity="0.35" Direction="270"/>
                    </Border.Effect>
                </Border>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Track"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#E74C3C" Duration="0:0:0.15"/>
                            <ColorAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#FFFFFF" Duration="0:0:0.15"/>
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="Margin"
                                To="22,0,0,0" Duration="0:0:0.15">
                                <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction>
                            </ThicknessAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Track"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#555555" Duration="0:0:0.15"/>
                            <ColorAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#AAAAAA" Duration="0:0:0.15"/>
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="Margin"
                                To="2,0,0,0" Duration="0:0:0.15">
                                <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction>
                            </ThicknessAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Track" Property="Opacity" Value="0.8"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Track" Property="Opacity" Value="0.3"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ═══════════════════════════════════════════════════════
         SEGMENTED CONTROL BUTTON  (one pill segment)
         x:Key used by RadioButton style in MainWindow
    ══════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="SegmentLight" TargetType="{x:Type RadioButton}">
        <Border x:Name="Bg" CornerRadius="6" Padding="10,5"
                Background="Transparent" SnapsToDevicePixels="True">
            <TextBlock x:Name="Label" Text="{TemplateBinding Content}"
                       FontSize="12" FontWeight="Normal"
                       Foreground="#555555"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Bg"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#FFFFFF" Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Bg"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#00FFFFFF" Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
                <Setter TargetName="Label" Property="FontWeight" Value="SemiBold"/>
                <Setter TargetName="Label" Property="Foreground" Value="#E74C3C"/>
                <Setter TargetName="Bg"    Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="4"
                                          Color="#000000" Opacity="0.10" Direction="270"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Label" Property="Foreground" Value="#222222"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Label" Property="Foreground" Value="#BBBBBB"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="SegmentDark" TargetType="{x:Type RadioButton}">
        <Border x:Name="Bg" CornerRadius="6" Padding="10,5"
                Background="Transparent" SnapsToDevicePixels="True">
            <TextBlock x:Name="Label" Text="{TemplateBinding Content}"
                       FontSize="12" FontWeight="Normal"
                       Foreground="#9D9D9D"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Bg"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#3D3D3D" Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Bg"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#003D3D3D" Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
                <Setter TargetName="Label" Property="FontWeight" Value="SemiBold"/>
                <Setter TargetName="Label" Property="Foreground" Value="#E74C3C"/>
                <Setter TargetName="Bg"    Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="4"
                                          Color="#000000" Opacity="0.25" Direction="270"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Label" Property="Foreground" Value="#E8E8E8"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Label" Property="Foreground" Value="#555555"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Segmented track container (the pill background) -->
    <Style x:Key="SegmentTrack" TargetType="{x:Type Border}">
        <Setter Property="Background"      Value="#EBEBEB"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="Padding"         Value="3"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>
    <Style x:Key="SegmentTrackDark" TargetType="{x:Type Border}">
        <Setter Property="Background"      Value="#252525"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="Padding"         Value="3"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         FOOTER BUTTON  — Win11 style with animated hover
    ══════════════════════════════════════════════════════════ -->
    <Style x:Key="CustomButton" TargetType="{x:Type Button}">
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="FontSize"       Value="13"/>
        <Setter Property="FontWeight"     Value="Normal"/>
        <Setter Property="Padding"        Value="16,7"/>
        <Setter Property="Cursor"         Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid>
                        <Border x:Name="Base" CornerRadius="5" BorderThickness="1"
                                BorderBrush="#22000000"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True"/>
                        <Border x:Name="Accent" CornerRadius="5"
                                Background="#E74C3C" Opacity="0" IsHitTestVisible="False"/>
                        <Border x:Name="Press" CornerRadius="5"
                                Background="#28000000" Opacity="0" IsHitTestVisible="False"/>
                        <ContentPresenter x:Name="Content" Focusable="False"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Accent"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Accent"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="#FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Press"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.7" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Press"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="#FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Base"    Property="Opacity" Value="0.4"/>
                            <Setter TargetName="Content" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════
         COMBOBOX (kept for SettingsWindow)
    ══════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="ComboBoxDark" TargetType="{x:Type ComboBox}">
        <Grid>
            <Border x:Name="OuterBorder" CornerRadius="5" BorderThickness="1"
                    BorderBrush="#606060" Background="#3A3A3A" SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      Margin="10,5,4,5" TextElement.FontSize="13"
                                      TextElement.Foreground="#E0E0E0"
                                      VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                                  IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                <Border Background="Transparent" CornerRadius="0,5,5,0">
                                    <Path x:Name="Arrow" HorizontalAlignment="Center"
                                          VerticalAlignment="Center" Fill="#E74C3C"
                                          Data="M0,0 L4,5 L8,0 Z"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                            <Setter.Value><RotateTransform Angle="180" CenterX="4" CenterY="2.5"/></Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </Grid>
            </Border>
            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                <Border Background="#2D2D2D" BorderBrush="#E74C3C" BorderThickness="1"
                        CornerRadius="5" MinWidth="{TemplateBinding ActualWidth}"
                        MaxHeight="{TemplateBinding MaxDropDownHeight}" Margin="0,2,0,0">
                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#E74C3C"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="ComboBoxWhite" TargetType="{x:Type ComboBox}">
        <Grid>
            <Border x:Name="OuterBorder" CornerRadius="5" BorderThickness="1"
                    BorderBrush="#C8C8C8" Background="#FFFFFF" SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      Margin="10,5,4,5" TextElement.FontSize="13"
                                      TextElement.Foreground="#222222"
                                      VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                                  IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                <Border Background="Transparent" CornerRadius="0,5,5,0">
                                    <Path x:Name="Arrow" HorizontalAlignment="Center"
                                          VerticalAlignment="Center" Fill="#E74C3C"
                                          Data="M0,0 L4,5 L8,0 Z"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                            <Setter.Value><RotateTransform Angle="180" CenterX="4" CenterY="2.5"/></Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </Grid>
            </Border>
            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                <Border Background="#FFFFFF" BorderBrush="#E74C3C" BorderThickness="1"
                        CornerRadius="5" MinWidth="{TemplateBinding ActualWidth}"
                        MaxHeight="{TemplateBinding MaxDropDownHeight}" Margin="0,2,0,0">
                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#E74C3C"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="ComboBoxItemDark" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="SnapsToDevicePixels" Value="true"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="OverridesDefaultStyle" Value="true"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="Border" CornerRadius="3" Margin="3,1" Background="Transparent">
                        <ContentPresenter TextElement.FontSize="13" Margin="8,5"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="true">
                            <Setter TargetName="Border" Property="Background" Value="#E74C3C"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ComboBoxItemWhite" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="SnapsToDevicePixels" Value="true"/>
        <Setter Property="Foreground" Value="#222222"/>
        <Setter Property="OverridesDefaultStyle" Value="true"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="Border" CornerRadius="3" Margin="3,1" Background="Transparent">
                        <ContentPresenter TextElement.FontSize="13" Margin="8,5"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="true">
                            <Setter TargetName="Border" Property="Background" Value="#E74C3C"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
