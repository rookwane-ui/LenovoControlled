<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         TOOLTIP  — Fluent acrylic-style card
    ════════════════════════════════════════════════════════════ -->
    <Style TargetType="{x:Type ToolTip}">
        <Style.Resources>
            <Style TargetType="{x:Type ContentPresenter}">
                <Style.Resources>
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="TextWrapping" Value="Wrap"/>
                    </Style>
                </Style.Resources>
            </Style>
        </Style.Resources>
        <Setter Property="MaxWidth"        Value="260"/>
        <Setter Property="Background"      Value="#F3F3F3"/>
        <Setter Property="Foreground"      Value="#1A1A1A"/>
        <Setter Property="BorderBrush"     Value="#E0E0E0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="10,6"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="HasDropShadow"   Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         BUTTON  — Win11 Fluent with smooth animated transitions
         States: Normal → Hover → Pressed → Disabled
    ════════════════════════════════════════════════════════════ -->
    <Style x:Key="CustomButton" TargetType="{x:Type Button}">
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="FontSize"       Value="13"/>
        <Setter Property="FontWeight"     Value="SemiBold"/>
        <Setter Property="Padding"        Value="12,6"/>
        <Setter Property="Cursor"         Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid>
                        <!-- Base layer — always visible, carries the border -->
                        <Border x:Name="BaseBorder"
                                CornerRadius="5"
                                BorderThickness="1"
                                BorderBrush="#22000000"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True"/>

                        <!-- Hover overlay — fades in -->
                        <Border x:Name="HoverLayer"
                                CornerRadius="5"
                                Background="#14000000"
                                Opacity="0"
                                IsHitTestVisible="False"/>

                        <!-- Press overlay — fades in on click -->
                        <Border x:Name="PressLayer"
                                CornerRadius="5"
                                Background="#22000000"
                                Opacity="0"
                                IsHitTestVisible="False"/>

                        <!-- Accent fill for hover (red) — separate so we can animate opacity -->
                        <Border x:Name="AccentLayer"
                                CornerRadius="5"
                                Background="#E74C3C"
                                Opacity="0"
                                IsHitTestVisible="False"/>

                        <ContentPresenter x:Name="Content"
                                          Focusable="False"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Grid>

                    <ControlTemplate.Triggers>

                        <!-- ── Hover: accent layer fades in, text turns white ── -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AccentLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AccentLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="#FFFFFF"/>
                        </Trigger>

                        <!-- ── Press: slightly darker, content dims ── -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.7" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="#FFFFFF"/>
                        </Trigger>

                        <!-- ── Disabled ── -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="BaseBorder" Property="Opacity" Value="0.4"/>
                            <Setter TargetName="Content"    Property="Opacity" Value="0.4"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════
         TOGGLE SWITCH — RadioButton  (Light)
         Pill track slides thumb with animation
    ════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="RadioButtonWhite" TargetType="{x:Type RadioButton}">
        <Grid Background="Transparent" SnapsToDevicePixels="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="42"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Track -->
            <Border x:Name="Track" Height="20" Width="38" CornerRadius="10"
                    Background="#DEDEDE" BorderBrush="#C0C0C0" BorderThickness="1"
                    HorizontalAlignment="Left" VerticalAlignment="Center">

                <!-- Thumb — positioned with margin animation -->
                <Border x:Name="Thumb" Height="13" Width="13" CornerRadius="7"
                        Background="#FFFFFF" VerticalAlignment="Center"
                        HorizontalAlignment="Left" Margin="2,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="2"
                                          Color="#000000" Opacity="0.2" Direction="270"/>
                    </Border.Effect>
                </Border>
            </Border>

            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"
                              HorizontalAlignment="Left" RecognizesAccessKey="True"
                              Margin="2,0,0,0"/>
        </Grid>
        <ControlTemplate.Triggers>

            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Track"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#E74C3C" Duration="0:0:0.15"/>
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                                Storyboard.TargetProperty="Margin"
                                                To="21,0,0,0" Duration="0:0:0.15">
                                <ThicknessAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </ThicknessAnimation.EasingFunction>
                            </ThicknessAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Track"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#DEDEDE" Duration="0:0:0.15"/>
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                                Storyboard.TargetProperty="Margin"
                                                To="2,0,0,0" Duration="0:0:0.15">
                                <ThicknessAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </ThicknessAnimation.EasingFunction>
                            </ThicknessAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>

            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Track" Property="Opacity" Value="0.82"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Track" Property="Opacity" Value="0.38"/>
                <Setter Property="Foreground" Value="#AAAAAA"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

