<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        DESIGN TOKENS  —  Warm Modern + Deep Crimson
        ───────────────────────────────────────────────────────
        Accent:        #C0392B   Accent hover:  #A93226
        Accent press:  #922B21

        Light bg:      #FAFAF8   Light card:    #F5F4F1
        Light border:  #E8E4DF   Light text:    #1C1917
        Light subtext: #78716C   Light input:   #FAFAF8

        Dark bg:       #1C1917   Dark card:     #292524
        Dark border:   #3C3835   Dark text:     #F5F0EB
        Dark subtext:  #A8A29E

        Heading font:  Segoe UI Variable Display
        Body font:     Segoe UI Variable Text
        ───────────────────────────────────────────────────────
    -->

    <!-- ── TOOLTIP ─────────────────────────────────────────── -->
    <Style TargetType="{x:Type ToolTip}">
        <Style.Resources>
            <Style TargetType="{x:Type ContentPresenter}">
                <Style.Resources>
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="TextWrapping" Value="Wrap"/>
                    </Style>
                </Style.Resources>
            </Style>
        </Style.Resources>
        <Setter Property="MaxWidth"        Value="260"/>
        <Setter Property="Background"      Value="#FAFAF8"/>
        <Setter Property="Foreground"      Value="#1C1917"/>
        <Setter Property="BorderBrush"     Value="#E8E4DF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="10,7"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="FontFamily"      Value="Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── CLASSIC CHECKBOX  (SettingsWindow) ───────────────── -->
    <ControlTemplate x:Key="CheckBoxWhite" TargetType="{x:Type CheckBox}">
        <Grid Background="Transparent" SnapsToDevicePixels="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="Border" Height="18" Width="18" CornerRadius="4"
                    Background="#FAFAF8" BorderBrush="#D6D0C8" BorderThickness="1.5"
                    HorizontalAlignment="Left" VerticalAlignment="Center">
                <Path x:Name="CheckMark" HorizontalAlignment="Center" VerticalAlignment="Center"
                      SnapsToDevicePixels="False" Stroke="#C0392B" StrokeThickness="2"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Data="M 2 5 L 6 9 L 13 2"/>
            </Border>
            <ContentPresenter Grid.Column="1" Margin="9,0,0,0"
                              VerticalAlignment="Center" RecognizesAccessKey="True"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="False">
                <Setter TargetName="CheckMark" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="BorderBrush" Value="#C0392B"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Border"    Property="Background"  Value="#F0EDE8"/>
                <Setter TargetName="Border"    Property="BorderBrush" Value="#DDD8D0"/>
                <Setter TargetName="CheckMark" Property="Stroke"      Value="#C8C2BA"/>
                <Setter Property="Foreground" Value="#A8A29E"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="CheckBoxDark" TargetType="{x:Type CheckBox}">
        <Grid Background="Transparent" SnapsToDevicePixels="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="Border" Height="18" Width="18" CornerRadius="4"
                    Background="#35FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1.5"
                    HorizontalAlignment="Left" VerticalAlignment="Center">
                <Path x:Name="CheckMark" HorizontalAlignment="Center" VerticalAlignment="Center"
                      SnapsToDevicePixels="False" Stroke="#C0392B" StrokeThickness="2"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Data="M 2 5 L 6 9 L 13 2"/>
            </Border>
            <ContentPresenter Grid.Column="1" Margin="9,0,0,0"
                              VerticalAlignment="Center" RecognizesAccessKey="True"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="False">
                <Setter TargetName="CheckMark" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="BorderBrush" Value="#C0392B"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Border"    Property="Background"  Value="#211E1C"/>
                <Setter TargetName="Border"    Property="BorderBrush" Value="#3C3835"/>
                <Setter TargetName="CheckMark" Property="Stroke"      Value="#57534E"/>
                <Setter Property="Foreground" Value="#57534E"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ── TOGGLE SWITCH  (MainWindow) ──────────────────────── -->
    <ControlTemplate x:Key="ToggleSwitchLight" TargetType="{x:Type CheckBox}">
        <Grid Background="Transparent" SnapsToDevicePixels="True" VerticalAlignment="Center">
            <Border x:Name="Track" Height="22" Width="42" CornerRadius="11"
                    Background="#D6D0C8" VerticalAlignment="Center">
                <Border x:Name="Thumb" Height="15" Width="15" CornerRadius="8"
                        Background="#FAFAF8" VerticalAlignment="Center"
                        HorizontalAlignment="Left" Margin="3,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="3"
                                          Color="#1C1917" Opacity="0.15" Direction="270"/>
                    </Border.Effect>
                </Border>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Track"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#C0392B" Duration="0:0:0.18"/>
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="Margin" To="23,0,0,0" Duration="0:0:0.18">
                                <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction>
                            </ThicknessAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Track"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#D6D0C8" Duration="0:0:0.18"/>
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="Margin" To="3,0,0,0" Duration="0:0:0.18">
                                <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction>
                            </ThicknessAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Track" Property="Opacity" Value="0.82"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Track" Property="Opacity" Value="0.38"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="ToggleSwitchDark" TargetType="{x:Type CheckBox}">
        <Grid Background="Transparent" SnapsToDevicePixels="True" VerticalAlignment="Center">
            <Border x:Name="Track" Height="22" Width="42" CornerRadius="11"
                    Background="#2A2018" VerticalAlignment="Center">
                <Border x:Name="Thumb" Height="15" Width="15" CornerRadius="8"
                        Background="#6B6560" VerticalAlignment="Center"
                        HorizontalAlignment="Left" Margin="3,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="3"
                                          Color="#000000" Opacity="0.35" Direction="270"/>
                    </Border.Effect>
                </Border>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Track"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#C0392B" Duration="0:0:0.18"/>
                            <ColorAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#F5F0EB" Duration="0:0:0.18"/>
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="Margin" To="23,0,0,0" Duration="0:0:0.18">
                                <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction>
                            </ThicknessAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Track"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#57534E" Duration="0:0:0.18"/>
                            <ColorAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#A8A29E" Duration="0:0:0.18"/>
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="Margin" To="3,0,0,0" Duration="0:0:0.18">
                                <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction>
                            </ThicknessAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Track" Property="Opacity" Value="0.82"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Track" Property="Opacity" Value="0.3"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ── SEGMENTED CONTROL ─────────────────────────────────── -->
    <ControlTemplate x:Key="SegmentLight" TargetType="{x:Type RadioButton}">
        <Border x:Name="Bg" CornerRadius="6" Padding="11,5"
                Background="Transparent" SnapsToDevicePixels="True">
            <TextBlock x:Name="Label" Text="{TemplateBinding Content}"
                       FontSize="12" FontWeight="Normal"
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       Foreground="#78716C"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Bg"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#FAFAF8" Duration="0:0:0.14"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Bg"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#00FAFAF8" Duration="0:0:0.14"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
                <Setter TargetName="Label" Property="FontWeight" Value="SemiBold"/>
                <Setter TargetName="Label" Property="Foreground"  Value="#C0392B"/>
                <Setter TargetName="Bg" Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="5"
                                          Color="#1C1917" Opacity="0.08" Direction="270"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Label" Property="Foreground" Value="#1C1917"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Label" Property="Foreground" Value="#C8C2BA"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="SegmentDark" TargetType="{x:Type RadioButton}">
        <Border x:Name="Bg" CornerRadius="6" Padding="11,5"
                Background="Transparent" SnapsToDevicePixels="True">
            <TextBlock x:Name="Label" Text="{TemplateBinding Content}"
                       FontSize="12" FontWeight="Normal"
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       Foreground="#C0B8B0"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Bg"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#50FFFFFF" Duration="0:0:0.14"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Bg"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#0050FFFFFF" Duration="0:0:0.14"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
                <Setter TargetName="Label" Property="FontWeight" Value="SemiBold"/>
                <Setter TargetName="Label" Property="Foreground"  Value="#C0392B"/>
                <Setter TargetName="Bg" Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="5"
                                          Color="#000000" Opacity="0.22" Direction="270"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Label" Property="Foreground" Value="#F2EDE8"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Label" Property="Foreground" Value="#706860"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ── BUTTON ────────────────────────────────────────────── -->
    <Style x:Key="CustomButton" TargetType="{x:Type Button}">
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="FontSize"         Value="13"/>
        <Setter Property="FontWeight"       Value="Normal"/>
        <Setter Property="FontFamily"       Value="Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="Padding"          Value="16,7"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid>
                        <Border x:Name="Base" CornerRadius="6" BorderThickness="1"
                                BorderBrush="#1A000000"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True"/>
                        <Border x:Name="Accent" CornerRadius="6"
                                Background="#C0392B" Opacity="0" IsHitTestVisible="False"/>
                        <Border x:Name="Press" CornerRadius="6"
                                Background="#922B21" Opacity="0" IsHitTestVisible="False"/>
                        <ContentPresenter x:Name="Content" Focusable="False"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Accent"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Accent"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="#FAFAF8"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Press"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.75" Duration="0:0:0.06"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Press"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="#FAFAF8"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Base"    Property="Opacity" Value="0.4"/>
                            <Setter TargetName="Content" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── COMBOBOX ──────────────────────────────────────────── -->
    <ControlTemplate x:Key="ComboBoxDark" TargetType="{x:Type ComboBox}">
        <Grid>
            <Border x:Name="OuterBorder" CornerRadius="6" BorderThickness="1"
                    BorderBrush="#30FFFFFF" Background="#40FFFFFF" SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      Margin="10,5,4,5" TextElement.FontSize="13"
                                      TextElement.Foreground="#F5F0EB"
                                      VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                                  IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                <Border Background="Transparent" CornerRadius="0,6,6,0">
                                    <Path x:Name="Arrow" HorizontalAlignment="Center"
                                          VerticalAlignment="Center" Fill="#C0392B"
                                          Data="M0,0 L4,5 L8,0 Z"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                            <Setter.Value><RotateTransform Angle="180" CenterX="4" CenterY="2.5"/></Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </Grid>
            </Border>
            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                <Border Background="#40FFFFFF" BorderBrush="#C0392B" BorderThickness="1"
                        CornerRadius="6" MinWidth="{TemplateBinding ActualWidth}"
                        MaxHeight="{TemplateBinding MaxDropDownHeight}" Margin="0,3,0,0">
                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#C0392B"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="ComboBoxWhite" TargetType="{x:Type ComboBox}">
        <Grid>
            <Border x:Name="OuterBorder" CornerRadius="6" BorderThickness="1"
                    BorderBrush="#D6D0C8" Background="#FAFAF8" SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      Margin="10,5,4,5" TextElement.FontSize="13"
                                      TextElement.Foreground="#1C1917"
                                      VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                                  IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                <Border Background="Transparent" CornerRadius="0,6,6,0">
                                    <Path x:Name="Arrow" HorizontalAlignment="Center"
                                          VerticalAlignment="Center" Fill="#C0392B"
                                          Data="M0,0 L4,5 L8,0 Z"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                            <Setter.Value><RotateTransform Angle="180" CenterX="4" CenterY="2.5"/></Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </Grid>
            </Border>
            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                <Border Background="#FAFAF8" BorderBrush="#C0392B" BorderThickness="1"
                        CornerRadius="6" MinWidth="{TemplateBinding ActualWidth}"
                        MaxHeight="{TemplateBinding MaxDropDownHeight}" Margin="0,3,0,0">
                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#C0392B"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="ComboBoxItemDark" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="SnapsToDevicePixels"   Value="true"/>
        <Setter Property="Foreground"            Value="#F5F0EB"/>
        <Setter Property="OverridesDefaultStyle" Value="true"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="Border" CornerRadius="4" Margin="3,1" Background="Transparent">
                        <ContentPresenter TextElement.FontSize="13" Margin="8,6"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="true">
                            <Setter TargetName="Border" Property="Background" Value="#C0392B"/>
                            <Setter Property="Foreground" Value="#FAFAF8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ComboBoxItemWhite" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="SnapsToDevicePixels"   Value="true"/>
        <Setter Property="Foreground"            Value="#1C1917"/>
        <Setter Property="OverridesDefaultStyle" Value="true"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="Border" CornerRadius="4" Margin="3,1" Background="Transparent">
                        <ContentPresenter TextElement.FontSize="13" Margin="8,6"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="true">
                            <Setter TargetName="Border" Property="Background" Value="#C0392B"/>
                            <Setter Property="Foreground" Value="#FAFAF8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
