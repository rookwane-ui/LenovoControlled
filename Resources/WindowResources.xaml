<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ╔══════════════════════════════════════════════════════════════════════╗
    ║  FLUENT 2 / WinUI 3 DESIGN TOKENS                                   ║
    ╠══════════════════════════════════════════════════════════════════════╣
    ║  Font:        Segoe UI Variable (Text axis for body, Display axis   ║
    ║               for headings)                                          ║
    ║  Type ramp:   Caption 12/16  Body 14/20  Subtitle 20/28             ║
    ║  Weight:      Regular (400) body,  Semibold (600) titles only        ║
    ║  Casing:      Sentence case everywhere                               ║
    ║  Grid:        40×40 epx touch target,  4px label gap,  8px gutter   ║
    ║  Radius:      Control = 4px  Card = 8px  Pill = 9999px              ║
    ║                                                                      ║
    ║  Light layer:                                                        ║
    ║    Bg        #F3F3F3  (SolidBackgroundFillColorBase)                ║
    ║    Card      #FFFFFF at 70% (CardBackgroundFillColorDefault)        ║
    ║    Border    #0000000E (CardStrokeColorDefault)                      ║
    ║    Text      #000000E4 (TextFillColorPrimary)                        ║
    ║    Subtext   #00000099 (TextFillColorSecondary)                      ║
    ║    Accent    #C0392B (brand crimson)                                 ║
    ║                                                                      ║
    ║  Dark layer:                                                         ║
    ║    Bg        Mica backdrop (transparent window)                      ║
    ║    Card      #FFFFFF0D (CardBackgroundFillColorDefault dark ~5%)     ║
    ║    Border    #FFFFFF14 (CardStrokeColorDefault dark ~8%)             ║
    ║    Text      #FFFFFFЕ4 (TextFillColorPrimary dark)                   ║
    ║    Subtext   #FFFFFF99 (TextFillColorSecondary dark ~60%)            ║
    ╚══════════════════════════════════════════════════════════════════════╝
    -->

    <!-- ── TOOLTIP ─────────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type ToolTip}">
        <Style.Resources>
            <Style TargetType="{x:Type ContentPresenter}">
                <Style.Resources>
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="TextWrapping" Value="Wrap"/>
                    </Style>
                </Style.Resources>
            </Style>
        </Style.Resources>
        <Setter Property="MaxWidth"        Value="260"/>
        <Setter Property="Background"      Value="#F9F9F9"/>
        <Setter Property="Foreground"      Value="#000000E4"/>
        <Setter Property="BorderBrush"     Value="#0000000E"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="12,8"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="FontFamily"      Value="Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── CLASSIC CHECKBOX  (SettingsWindow) ────────────────────────── -->
    <!-- WinUI CheckBox: 20×20 box, CornerRadius=4, 2px border, checkmark SVG path -->
    <ControlTemplate x:Key="CheckBoxWhite" TargetType="{x:Type CheckBox}">
        <Grid Background="Transparent" SnapsToDevicePixels="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="Box" Height="20" Width="20" CornerRadius="4"
                    Background="#FFFFFF" BorderBrush="#00000073" BorderThickness="1.5"
                    VerticalAlignment="Center" HorizontalAlignment="Left">
                <Path x:Name="Check" Data="M 3 9 L 7.5 13.5 L 14 5"
                      Stroke="#FFFFFF" StrokeThickness="1.8"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      SnapsToDevicePixels="False"/>
            </Border>
            <ContentPresenter Grid.Column="1" Margin="8,0,0,0"
                              VerticalAlignment="Center" RecognizesAccessKey="True"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="False">
                <Setter TargetName="Check"   Property="Visibility"   Value="Collapsed"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Box"     Property="Background"   Value="#C0392B"/>
                <Setter TargetName="Box"     Property="BorderBrush"  Value="#C0392B"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Box"     Property="BorderBrush"  Value="#C0392B"/>
            </Trigger>
            <Trigger Property="IsEnabled"   Value="False">
                <Setter TargetName="Box"     Property="Opacity"      Value="0.38"/>
                <Setter Property="Foreground" Value="#00000072"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="CheckBoxDark" TargetType="{x:Type CheckBox}">
        <Grid Background="Transparent" SnapsToDevicePixels="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="Box" Height="20" Width="20" CornerRadius="4"
                    Background="#FFFFFF14" BorderBrush="#FFFFFF8B" BorderThickness="1.5"
                    VerticalAlignment="Center" HorizontalAlignment="Left">
                <Path x:Name="Check" Data="M 3 9 L 7.5 13.5 L 14 5"
                      Stroke="#FFFFFFE4" StrokeThickness="1.8"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      SnapsToDevicePixels="False"/>
            </Border>
            <ContentPresenter Grid.Column="1" Margin="8,0,0,0"
                              VerticalAlignment="Center" RecognizesAccessKey="True"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="False">
                <Setter TargetName="Check"   Property="Visibility"   Value="Collapsed"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Box"     Property="Background"   Value="#C0392B"/>
                <Setter TargetName="Box"     Property="BorderBrush"  Value="#C0392B"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Box"     Property="BorderBrush"  Value="#C0392B"/>
            </Trigger>
            <Trigger Property="IsEnabled"   Value="False">
                <Setter TargetName="Box"     Property="Opacity"      Value="0.38"/>
                <Setter Property="Foreground" Value="#FFFFFF72"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ── TOGGLE SWITCH  (MainWindow card rows) ─────────────────────── -->
    <!-- WinUI ToggleSwitch: 40×20 pill, 14px thumb, no border on track   -->
    <ControlTemplate x:Key="ToggleSwitchLight" TargetType="{x:Type CheckBox}">
        <Grid Background="Transparent" SnapsToDevicePixels="True" VerticalAlignment="Center">
            <Border x:Name="Track" Height="20" Width="40" CornerRadius="10"
                    Background="#00000073" VerticalAlignment="Center">
                <Border x:Name="Thumb" Height="12" Width="12" CornerRadius="6"
                        Background="#FFFFFF" VerticalAlignment="Center"
                        HorizontalAlignment="Left" Margin="3,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="2"
                                          Color="#000000" Opacity="0.14"/>
                    </Border.Effect>
                </Border>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Track"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#C0392B" Duration="0:0:0.167"/>
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="Margin"
                                To="23,0,0,0" Duration="0:0:0.167">
                                <ThicknessAnimation.EasingFunction>
                                    <CircleEase EasingMode="EaseOut"/>
                                </ThicknessAnimation.EasingFunction>
                            </ThicknessAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Track"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#00000073" Duration="0:0:0.167"/>
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="Margin"
                                To="3,0,0,0" Duration="0:0:0.167">
                                <ThicknessAnimation.EasingFunction>
                                    <CircleEase EasingMode="EaseOut"/>
                                </ThicknessAnimation.EasingFunction>
                            </ThicknessAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Track" Property="Opacity" Value="0.8"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Track" Property="Opacity" Value="0.38"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="ToggleSwitchDark" TargetType="{x:Type CheckBox}">
        <Grid Background="Transparent" SnapsToDevicePixels="True" VerticalAlignment="Center">
            <Border x:Name="Track" Height="20" Width="40" CornerRadius="10"
                    Background="#FFFFFF8B" VerticalAlignment="Center">
                <Border x:Name="Thumb" Height="12" Width="12" CornerRadius="6"
                        Background="#000000" VerticalAlignment="Center"
                        HorizontalAlignment="Left" Margin="3,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="2"
                                          Color="#000000" Opacity="0.35"/>
                    </Border.Effect>
                </Border>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Track"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#C0392B" Duration="0:0:0.167"/>
                            <ColorAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#FFFFFF" Duration="0:0:0.167"/>
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="Margin"
                                To="23,0,0,0" Duration="0:0:0.167">
                                <ThicknessAnimation.EasingFunction>
                                    <CircleEase EasingMode="EaseOut"/>
                                </ThicknessAnimation.EasingFunction>
                            </ThicknessAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Track"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#FFFFFF8B" Duration="0:0:0.167"/>
                            <ColorAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#000000" Duration="0:0:0.167"/>
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                Storyboard.TargetProperty="Margin"
                                To="3,0,0,0" Duration="0:0:0.167">
                                <ThicknessAnimation.EasingFunction>
                                    <CircleEase EasingMode="EaseOut"/>
                                </ThicknessAnimation.EasingFunction>
                            </ThicknessAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Track" Property="Opacity" Value="0.8"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Track" Property="Opacity" Value="0.38"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ── SEGMENTED CONTROL ─────────────────────────────────────────── -->
    <!-- WinUI-style pill selector: subtle background, accent on selected  -->
    <ControlTemplate x:Key="SegmentLight" TargetType="{x:Type RadioButton}">
        <Border x:Name="Bg" CornerRadius="4" Padding="12,6"
                Background="Transparent" SnapsToDevicePixels="True">
            <TextBlock x:Name="Label" Text="{TemplateBinding Content}"
                       FontSize="13" FontWeight="Normal"
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       Foreground="#00000099"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Bg"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#FFFFFFFF" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Bg"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#00FFFFFF" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
                <Setter TargetName="Label" Property="FontWeight" Value="SemiBold"/>
                <Setter TargetName="Label" Property="Foreground"  Value="#C0392B"/>
                <Setter TargetName="Bg"    Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="4"
                                          Color="#000000" Opacity="0.06"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Label" Property="Foreground" Value="#000000E4"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Label" Property="Foreground" Value="#00000038"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="SegmentDark" TargetType="{x:Type RadioButton}">
        <Border x:Name="Bg" CornerRadius="4" Padding="12,6"
                Background="Transparent" SnapsToDevicePixels="True">
            <TextBlock x:Name="Label" Text="{TemplateBinding Content}"
                       FontSize="13" FontWeight="Normal"
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       Foreground="#FFFFFF99"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Bg"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#FFFFFF1F" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="Bg"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#00FFFFFF" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
                <Setter TargetName="Label" Property="FontWeight" Value="SemiBold"/>
                <Setter TargetName="Label" Property="Foreground"  Value="#C0392B"/>
                <Setter TargetName="Bg"    Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="4"
                                          Color="#000000" Opacity="0.18"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Label" Property="Foreground" Value="#FFFFFFE4"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Label" Property="Foreground" Value="#FFFFFF38"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ── BUTTON  ────────────────────────────────────────────────────── -->
    <!-- WinUI Button: CornerRadius=4, SubtleFill background, accent hover -->
    <Style x:Key="CustomButton" TargetType="{x:Type Button}">
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="FontWeight"       Value="Normal"/>
        <Setter Property="FontFamily"       Value="Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="Padding"          Value="16,8"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid>
                        <Border x:Name="Base" CornerRadius="4"
                                BorderThickness="1" BorderBrush="#0000000F"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True"/>
                        <Border x:Name="Hover" CornerRadius="4"
                                Background="#000000" Opacity="0" IsHitTestVisible="False"/>
                        <Border x:Name="Accent" CornerRadius="4"
                                Background="#C0392B" Opacity="0" IsHitTestVisible="False"/>
                        <ContentPresenter x:Name="Content" Focusable="False"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Accent"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.167"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Accent"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.167"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="#FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.72" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Content"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="#FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Base"    Property="Opacity" Value="0.38"/>
                            <Setter TargetName="Content" Property="Opacity" Value="0.38"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── COMBOBOX  ─────────────────────────────────────────────────── -->
    <ControlTemplate x:Key="ComboBoxDark" TargetType="{x:Type ComboBox}">
        <Grid>
            <Border x:Name="OuterBorder" CornerRadius="4" BorderThickness="1"
                    BorderBrush="#FFFFFF8B" Background="#FFFFFF0D" SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      Margin="10,6,4,6" TextElement.FontSize="14"
                                      TextElement.Foreground="#FFFFFFE4"
                                      VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                                  IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                <Border Background="Transparent">
                                    <Path x:Name="Arrow" HorizontalAlignment="Center"
                                          VerticalAlignment="Center" Fill="#FFFFFFE4"
                                          Data="M0,0 L4,5 L8,0 Z"/>
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </Grid>
            </Border>
            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                <Border Background="#2C2C2C" BorderBrush="#FFFFFF14" BorderThickness="1"
                        CornerRadius="4" MinWidth="{TemplateBinding ActualWidth}"
                        MaxHeight="{TemplateBinding MaxDropDownHeight}" Margin="0,4,0,0">
                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True"
                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#C0392B"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="ComboBoxWhite" TargetType="{x:Type ComboBox}">
        <Grid>
            <Border x:Name="OuterBorder" CornerRadius="4" BorderThickness="1"
                    BorderBrush="#00000073" Background="#FFFFFF" SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      Margin="10,6,4,6" TextElement.FontSize="14"
                                      TextElement.Foreground="#000000E4"
                                      VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                                  IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                <Border Background="Transparent">
                                    <Path x:Name="Arrow" HorizontalAlignment="Center"
                                          VerticalAlignment="Center" Fill="#000000E4"
                                          Data="M0,0 L4,5 L8,0 Z"/>
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </Grid>
            </Border>
            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                <Border Background="#FFFFFF" BorderBrush="#0000000E" BorderThickness="1"
                        CornerRadius="4" MinWidth="{TemplateBinding ActualWidth}"
                        MaxHeight="{TemplateBinding MaxDropDownHeight}" Margin="0,4,0,0">
                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True"
                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#C0392B"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="ComboBoxItemDark" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="SnapsToDevicePixels"   Value="True"/>
        <Setter Property="Foreground"            Value="#FFFFFFE4"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="Bg" CornerRadius="4" Margin="4,2" Background="Transparent">
                        <ContentPresenter TextElement.FontSize="14" Margin="8,6"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#C0392B"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ComboBoxItemWhite" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="SnapsToDevicePixels"   Value="True"/>
        <Setter Property="Foreground"            Value="#000000E4"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="Bg" CornerRadius="4" Margin="4,2" Background="Transparent">
                        <ContentPresenter TextElement.FontSize="14" Margin="8,6"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#C0392B"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
